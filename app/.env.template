# Databricks workspace profile (must match a section in ~/.databrickscfg)
DATABRICKS_CONFIG_PROFILE=fevm-hsbc-fraud-ai-ml

# Lakebase connection (local development)
# Get these from the Lakebase UI Connect dialog or via:
#   from databricks.sdk import WorkspaceClient
#   w = WorkspaceClient(profile="fevm-hsbc-fraud-ai-ml")
#   ep = w.postgres.get_endpoint(name="projects/<project>/branches/production/endpoints/primary")
LAKEBASE_ENDPOINT=projects/retailfrauddb/branches/production/endpoints/primary
LAKEBASE_HOST=ep-silent-wildflower-d8nbcx5q.database.us-east-2.cloud.databricks.com
LAKEBASE_DATABASE=databricks_postgres
LAKEBASE_USER=ed.bullen@databricks.com

# Set to "true" to force in-memory mock (ignores Lakebase config)
# USE_MOCK_DATA=true

# Kafka (Confluent Cloud -- SASL_SSL with API key auth)
# Get these from your Confluent Cloud cluster settings
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-2.aws.confluent.cloud:9092
KAFKA_API_KEY=<your-confluent-api-key>
KAFKA_API_SECRET=<your-confluent-api-secret>

# Model Serving
MODEL_SERVING_ENDPOINT=bank-fraud-predict

# Unity Catalog
UNITY_CATALOG=hsbc_fraud_ai_ml_catalog
UNITY_SCHEMA=retail-bank

# SQL Warehouse (for profiling script only -- not needed at app runtime)
# SQL_WAREHOUSE_ID=<your-warehouse-id>

# Generator tuning: fraction of txns generated with fraud-like feature distributions
# The model then decides whether they are actually fraud (default 0.15 = 15%)
FRAUD_INJECTION_RATE=0.30

{
  "datasets": [
    {
      "name": "d43c8cd6",
      "displayName": "inter_country_flow",
      "queryLines": [
        "select countryOrig , countryDest , type, value from (\n",
        "    select countryOrig , countryDest , type, count(amount ) as value\n",
        "    from gold_transactions\n",
        "    where amount > 350000\n",
        "    group by countryOrig , countryDest ,type\n",
        ") order by value desc\n",
        "limit 20\n",
        "\n"
      ],
      "catalog": "main",
      "schema": "ed_bullen"
    },
    {
      "name": "7aae52c0",
      "displayName": "amount_per_country",
      "queryLines": [
        "-- NOTE: set the Unity Catalog and Schema as appropriate to pick up the location of view gold_transactions\n",
        "SELECT countryOrig , countryDest , type, value\n",
        "FROM (\n",
        "    select countryOrig , countryDest , type, sum(amount ) as value\n",
        "    from gold_transactions\n",
        "    where is_fraud and amount > 350000\n",
        "    group by countryOrig , countryDest ,type\n",
        ")\n"
      ],
      "catalog": "main",
      "schema": "ed_bullen"
    },
    {
      "name": "d1fb5a09",
      "displayName": "fraud_type_by_country",
      "queryLines": [
        "select type, is_fraud, countryOrig, count(1) as count\n",
        "from gold_transactions\n",
        "group by type, is_fraud, countryOrig;"
      ],
      "catalog": "main",
      "schema": "ed_bullen"
    },
    {
      "name": "18e19e3b",
      "displayName": "timeseries",
      "queryLines": [
        "-- Select the count and amount / value of fraud transactions over time - chunked into 1 hr series\n",
        "-- use this for populating the Fraud over time sample dashboard, as shown in the README screenshot\n",
        "\n",
        "-- NOTE: set the Unity Catalog and Schema as appropriate to pick up the location of view gold_transactions\n",
        "SELECT ts, count(1) nbFraudTransactions, sum(amount) sumFraudTransactions\n",
        "FROM (\n",
        "    select from_unixtime(unix_timestamp(current_timestamp()) + (step * 3600)) ts, amount\n",
        "    from gold_transactions\n",
        "    join (--just getting the last 30 days\n",
        "        select max(step)-(24*30) windowStart, max(step) windowEnd\n",
        "        from gold_transactions\n",
        "    ) on step >= windowStart and step <= windowEnd\n",
        "    where is_fraud\n",
        ")\n",
        "GROUP BY ts\n",
        "ORDER BY ts"
      ],
      "catalog": "main",
      "schema": "ed_bullen"
    },
    {
      "name": "c4f11f78",
      "displayName": "Untitled dataset",
      "queryLines": [
        ""
      ]
    }
